--// TOGGLE GUI BUTTON
local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Size = UDim2.new(0,120,0,40)
ToggleBtn.Position = UDim2.new(0,20,0.5,-20)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
ToggleBtn.Text = "Toggle UI"
ToggleBtn.TextColor3 = Color3.fromRGB(255,255,255)
ToggleBtn.TextScaled = true
ToggleBtn.Parent = game.CoreGui

Instance.new("UICorner", ToggleBtn)

local UIVisible = true

local function ToggleUI()
    UIVisible = not UIVisible
    for _,v in pairs(game.CoreGui:GetChildren()) do
        if v.Name == "Rayfield" then
            v.Enabled = UIVisible
        end
    end
end

ToggleBtn.MouseButton1Click:Connect(ToggleUI)

UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        ToggleUI()
    end
end)

--// MAIN LOOP
RunService.RenderStepped:Connect(function()

    -- FOV
    FOV.Size = UDim2.new(0, Config.FOV, 0, Config.FOV)
    FOV.Visible = Config.Aimbot

    GetTarget()

    -- AIMBOT
    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)
    end

    -- ESP
    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then

            local esp = ESP[p]
            local char = p.Character

            if not esp or not char then continue end

            local root = char:FindFirstChild("HumanoidRootPart")

            if not root or GetHealth(char) <= 0 or not Config.ESP then
                esp.GUI.Enabled = false
                continue
            end

            local role = GetRole(p,char)
            local color = GetColor(role)

            esp.GUI.Adornee = root
            esp.GUI.Enabled = true
            esp.Text.Text = p.Name.." ["..role.."]"
            esp.Text.TextColor3 = color
        end
    end
end)
