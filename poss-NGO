    return
end

--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

--// CONFIG
local Config = {
    ESP = true,
    Aimbot = false,
    TeamCheck = true,
    FOV = 180
}

--// UI WINDOW
local Window = Rayfield:CreateWindow({
    Name = "BANANA ELITE 🍌",
    LoadingTitle = "BANANA ELITE",
    LoadingSubtitle = "Stable Version",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")

--// FOV CIRCLE (SAFE)
local FOV = Instance.new("Frame")
FOV.Size = UDim2.new(0, Config.FOV, 0, Config.FOV)
FOV.AnchorPoint = Vector2.new(0.5,0.5)
FOV.Position = UDim2.new(0.5,0,0.5,0)
FOV.BackgroundTransparency = 1
FOV.Parent = game.CoreGui

local stroke = Instance.new("UIStroke", FOV)
stroke.Thickness = 2
stroke.Color = Color3.fromRGB(0,255,255)

Instance.new("UICorner", FOV).CornerRadius = UDim.new(1,0)

--// FUNCTIONS

local function GetHealth(character)
    local hum = character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health or 0
end

local function GetRole(player, character)
    if player.Team and player.Team.Name ~= "" then
        return player.Team.Name
    end

    local stats = player:FindFirstChild("leaderstats")
    if stats then
        for _,v in pairs(stats:GetChildren()) do
            if tostring(v.Name):lower():find("team") then
                return tostring(v.Value)
            end
        end
    end

    if character then
        for _,v in pairs(character:GetChildren()) do
            if v:IsA("StringValue") then
                return tostring(v.Value)
            end
        end
    end

    return "Unknown"
end

local function GetColor(role)
    role = tostring(role):lower()

    if role:find("red") then
        return Color3.fromRGB(255,0,0)
    elseif role:find("blue") then
        return Color3.fromRGB(0,170,255)
    end

    return Color3.fromRGB(255,255,255)
end

local function IsEnemy(player, character)
    if not Config.TeamCheck then return true end

    local myRole = GetRole(LocalPlayer, LocalPlayer.Character)
    local targetRole = GetRole(player, character)

    return myRole ~= targetRole
end

--// ESP SYSTEM
local ESP = {}

local function RemoveESP(player)
    if ESP[player] then
        ESP[player].GUI:Destroy()
        ESP[player] = nil
    end
end

Players.PlayerRemoving:Connect(RemoveESP)

local function CreateESP(player)
    if player == LocalPlayer then return end

    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(0,200,0,50)
    gui.AlwaysOnTop = true
    gui.Parent = game.CoreGui

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextScaled = true
    text.TextStrokeTransparency = 0
    text.Parent = gui

    ESP[player] = {GUI=gui, Text=text}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

--// TARGET SYSTEM
local LockedTarget = nil

local function GetTarget()
    local closest = nil
    local shortest = Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local head = char:FindFirstChild("Head")

            if head and GetHealth(char) > 0 and IsEnemy(p,char) then
                local pos, visible = Camera:WorldToViewportPoint(head.Position)

                if visible then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local dist = dx*dx + dy*dy

                    if dist < shortest then
                        shortest = dist
                        closest = head
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

