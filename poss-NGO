--// TEAM DETECT (ADVANCED FIX)
local function GetTeam(p)
    -- Method 1: Roblox Team
    if p.Team and p.Team.Name ~= "" then
        return p.Team.Name
    end

    -- Method 2: TeamColor
    if p.TeamColor then
        return p.TeamColor.Name
    end

    -- Method 3: Character values
    if p.Character then
        for _,v in pairs(p.Character:GetChildren()) do
            if v:IsA("StringValue") then
                return tostring(v.Value)
            end
        end
    end

    return "UNKNOWN"
end

local function GetColor(team)
    local t = tostring(team):lower()

    if t:find("red") then return Color3.fromRGB(255,0,0)
    elseif t:find("blue") then return Color3.fromRGB(0,170,255)
    elseif t:find("enemy") then return Color3.fromRGB(255,0,0)
    elseif t:find("ally") then return Color3.fromRGB(0,255,0)
    end

    return Color3.fromRGB(255,255,255)
end

local function IsEnemy(p)
    if not Config.TeamCheck then return true end
    return GetTeam(p) ~= GetTeam(LocalPlayer)
end

--// WALL CHECK
local function IsVisible(part)
    if not Config.WallCheck then return true end

    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)

    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end

    return true
end

--// HEALTH
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

--// ESP
local ESP = {}

local function RemoveESP(p)
    if ESP[p] then
        ESP[p].GUI:Destroy()
        ESP[p] = nil
    end
end

Players.PlayerRemoving:Connect(RemoveESP)

local function CreateESP(p)
    if p == LocalPlayer then return end

    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(0,200,0,50)
    gui.AlwaysOnTop = true
    gui.Parent = game.CoreGui

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextScaled = true
    text.TextStrokeTransparency = 0
    text.Parent = gui

    ESP[p] = {GUI=gui, Text=text}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

--// TARGET
local LockedTarget = nil

local function GetTarget()
    local closest = nil
    local shortest = Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local head = char:FindFirstChild("Head")

            if head and GetHealth(char) > 0 and IsEnemy(p) and IsVisible(head) then
                local pos, visible = Camera:WorldToViewportPoint(head.Position)

                if visible then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local dist = dx*dx + dy*dy

                    if dist < shortest then
                        shortest = dist
                        closest = head
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

